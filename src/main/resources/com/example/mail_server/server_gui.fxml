<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.TextFlow?>
<StackPane xmlns:fx="http://javafx.com/fxml/1" prefHeight="700.0" prefWidth="1100.0"
           xmlns="http://javafx.com/javafx/21"
           fx:controller="com.example.mail_server.controller.Server_Controller"
           stylesheets="@server_styles.css">

    <BorderPane>
        <top>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <padding>
                    <Insets top="15.0" right="20.0" bottom="15.0" left="20.0"/>
                </padding>
                <Label text="Mail Server Console"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #102a43;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Status: ONLINE" styleClass="status-badge"/>
                <Button fx:id="button_clear_logs" text="Clear Logs" onAction="#on_clear_logs_clicked"
                        styleClass="danger-button"/>
            </HBox>
        </top>

        <center>
            <SplitPane dividerPositions="0.25" styleClass="glass-split-pane">
                <items>

                    <VBox spacing="10.0">
                        <padding>
                            <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
                        </padding>
                        <Label text="Server Info"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #334e68;"/>
                        <TextArea fx:id="text_area_info" editable="false" wrapText="true" VBox.vgrow="ALWAYS"
                                  styleClass="glass-text-area"/>
                    </VBox>

                    <VBox spacing="10.0">
                        <padding>
                            <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
                        </padding>
                        <Label text="Live System Logs"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #334e68;"/>
                        <ScrollPane fx:id="scroll_pane_logs" fitToWidth="true" VBox.vgrow="ALWAYS"
                                    styleClass="glass-text-area">
                            <content>
                                <TextFlow fx:id="text_flow_logs">
                                    <padding>
                                        <Insets top="10" right="10" bottom="10" left="10"/>
                                    </padding>
                                </TextFlow>
                            </content>
                        </ScrollPane>
                    </VBox>

                </items>
            </SplitPane>
        </center>
    </BorderPane>

</StackPane>